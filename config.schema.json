{
  "pluginAlias": "GrowattSystem",
  "pluginType": "platform",
  "singular": false,
  "headerDisplay": "<h3>Homebridge Growatt System</h3><p>Connects Growatt OpenAPI plants and devices to HomeKit with stable accessory IDs and rate-limit aware updates.</p>",
  "footerDisplay": "<p>Get a token from <a href=\"https://openapi.growatt.com\" target=\"_blank\">Growatt OpenAPI</a>, then restart Homebridge after saving.</p>",
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Platform Name",
        "type": "string",
        "default": "Growatt Solar",
        "required": true,
        "minLength": 1,
        "maxLength": 50
      },
      "token": {
        "title": "Growatt API Token",
        "type": "string",
        "required": true,
        "minLength": 20
      },
      "refreshInterval": {
        "title": "Refresh Interval",
        "type": "integer",
        "default": 15,
        "minimum": 5,
        "maximum": 60,
        "description": "Minutes between Growatt API updates. Lower values are more likely to hit Growatt rate limits."
      },
      "showMonthlyEnergy": {
        "title": "Show Monthly Energy",
        "type": "boolean",
        "default": false
      },
      "showYearlyEnergy": {
        "title": "Show Yearly Energy",
        "type": "boolean",
        "default": false
      },
      "debugApi": {
        "title": "Debug API Responses",
        "type": "boolean",
        "default": false
      }
    },
    "required": [
      "name",
      "token"
    ]
  },
  "layout": [
    {
      "type": "fieldset",
      "title": "Basic Settings",
      "expandable": false,
      "items": [
        "name",
        "token",
        "refreshInterval"
      ]
    },
    {
      "type": "fieldset",
      "title": "Optional Metrics",
      "expandable": true,
      "expanded": false,
      "items": [
        "showMonthlyEnergy",
        "showYearlyEnergy"
      ]
    },
    {
      "type": "fieldset",
      "title": "Diagnostics",
      "expandable": true,
      "expanded": false,
      "items": [
        "debugApi"
      ]
    }
  ]
}
